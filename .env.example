# ============================================
# KIVI AI TaskOS Console — 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入你的配置。
# .env 文件已被 .gitignore 排除，不会提交到 Git。
#
# 你也可以在 Web 页面右上角点击「AI 配置」使用自己的 API Key，
# 无需修改此文件。

# ---- AI 平台配置（可选）----
# AI 平台: deepseek | openai | anthropic | gemini | openrouter | ollama | custom
# 用户在页面配置后会覆盖此处的默认值。

# DeepSeek API Key（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=your-api-key-here

# DeepSeek API 地址
DEEPSEEK_BASE_URL=https://api.deepseek.com

# DeepSeek 模型名称
DEEPSEEK_MODEL=deepseek-chat

# ---- 服务器配置 ----
# 服务端口
PORT=3001

# GitHub Search API Token（用于 Step 7 开源能力搜索）
# 建议使用 fine-grained token；至少需要访问公开仓库搜索能力。
GITHUB_TOKEN=your-github-token-here

# KIVIDAILYLIFE 母库路径（绝对路径或相对路径）
KIVIDAILYLIFE_PATH=../KIVIDAILYLIFE
